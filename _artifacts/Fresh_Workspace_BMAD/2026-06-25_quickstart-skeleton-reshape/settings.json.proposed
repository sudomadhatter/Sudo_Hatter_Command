// PROPOSED replacement for Projects/clean-bmad-workspace/.claude/settings.json
// (I could not write this myself — auto-mode guards self-modifying startup config. Review + apply.)
// It ADDS the "hooks" block; the existing "permissions" block is preserved verbatim.
// Drift call uses -ExecutionPolicy Bypass so the local .ps1 runs regardless of your machine policy;
// drop it if your policy already allows local scripts.
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$d = $env:CLAUDE_PROJECT_DIR; $ac = Join-Path $d '../../_artifacts/clean-bmad-workspace/active-context.md'; $rm = Join-Path $d 'docs/repo-map.md'; Write-Output '# clean-bmad continuity + gate (auto-injected at SessionStart)'; if (Test-Path $ac) { Get-Content -Raw -Encoding UTF8 $ac }; Write-Output ''; Write-Output 'ARTIFACTS GATE: no edits outside _artifacts/ without an approved implementation_plan.md (AGENTS.md section 5). GIT: hand Daniel the exact command; never commit/push yourself unless he delegates it (git-policy).'; Write-Output ''; Write-Output '# Repo-map index (docs/repo-map.md) - your navigation map:'; if (Test-Path $rm) { Get-Content -Raw -Encoding UTF8 $rm }\""
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path $env:CLAUDE_PROJECT_DIR 'scripts/check-repo-map-drift.ps1')\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx --yes bmad-method install --list-tools)",
      "Bash(npx --yes bmad-method install --yes --action update --tools claude-code,antigravity)",
      "Bash(npx --yes bmad-method install --help)",
      "Bash(git checkout *)",
      "Bash(git check-ignore *)",
      "Bash(echo \"exit: $?\")",
      "Bash(grep -iE 'stories/.*\\.md$')",
      "Bash(awk *)"
    ],
    "additionalDirectories": [
      "c:\\Sudo_Hatter_Command\\clean-bmad-workspace\\_claude_artifacts"
    ]
  }
}
